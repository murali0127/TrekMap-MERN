<% layout('layouts/boilerplate') %>

      <!-- Hero Section with Carousel -->
      <section class="hero-section position-relative overflow-hidden">
            <!-- Hero Carousel Background -->
            <div id="heroCarousel" class="carousel slide carousel-fade hero-carousel" data-bs-ride="carousel"
                  data-bs-interval="2000">
                  <!-- Carousel Indicators -->
                  <div class="carousel-indicators">
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"
                              aria-current="true" aria-label="Slide 1"></button>
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"
                              aria-label="Slide 2"></button>
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"
                              aria-label="Slide 3"></button>
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="3"
                              aria-label="Slide 4"></button>
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="4"
                              aria-label="Slide 5"></button>
                  </div>

                  <!-- Carousel Slides -->
                  <div class="carousel-inner">
                        <div class="carousel-item active">
                              <img src="https://images.unsplash.com/photo-1543798111-4a5163ab16a1?w=1920&auto=format&fit=crop&q=80"
                                    class="d-block w-100 hero-slide" alt="Mountain trekking adventure">
                        </div>
                        <div class="carousel-item">
                              <img src="https://images.unsplash.com/photo-1659945879508-8ec2dde10b7d?w=1920&auto=format&fit=crop&q=80"
                                    class="d-block w-100 hero-slide" alt="Scenic mountain trail">
                        </div>
                        <div class="carousel-item">
                              <img src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1920&auto=format&fit=crop&q=80"
                                    class="d-block w-100 hero-slide" alt="Majestic mountain peaks">
                        </div>
                        <div class="carousel-item">
                              <img src="https://images.unsplash.com/photo-1551632811-561732d1e306?w=1920&auto=format&fit=crop&q=80"
                                    class="d-block w-100 hero-slide" alt="Forest trekking path">
                        </div>
                        <div class="carousel-item">
                              <img src="https://images.unsplash.com/photo-1666728975757-488b391ac98c?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MjQ5fHx0cmVra2luZ3N8ZW58MHwwfDB8fHww0"
                                    class="d-block w-100 hero-slide" alt="Istanbul Forest Turkey">
                        </div>
                  </div>

            </div>

            <!-- Dark Overlay -->
            <div class="hero-overlay"></div>

            <!-- Hero Content -->
            <div class="container position-relative" style="z-index: 2;">
                  <div class="row align-items-center min-vh-75">
                        <div class="col-lg-8 mx-auto text-center">
                              <h1 class="display-3 fw-bold text-white mb-4 animate-fade-in">
                                    Welcome to <span class="text-primary">TrekMap</span>
                              </h1>
                              <p class="lead text-white mb-5 hero-description">
                                    Discover amazing trekking spots, share your adventures, and connect with
                                    fellow
                                    trekkers.
                                    Your next adventure starts here!
                              </p>
                              <div class="d-flex justify-content-center gap-3 flex-wrap">
                                    <a href="/treks" class="btn btn-primary btn-lg px-5">
                                          Explore Treks
                                    </a>
                                    <a href="/treks/new" class="btn btn-outline-light btn-lg px-4">
                                          Add New
                                    </a>
                              </div>
                        </div>
                  </div>
            </div>
      </section>

      <!-- Features Section -->
      <section class="py-5">
            <div class="container">
                  <div class="row g-4">
                        <div class="col-md-4">
                              <div class="feature-card text-center p-4 rounded">
                                    <div class="feature-icon mb-3">
                                          <i class="bi bi-geo-alt fs-1 text-primary"></i>
                                    </div>
                                    <h4>Discover Locations</h4>
                                    <p class="text-secondary">Find the best trekking spots with detailed information
                                          about each location.</p>
                              </div>
                        </div>
                        <div class="col-md-4">
                              <div class="feature-card text-center p-4 rounded">
                                    <div class="feature-icon mb-3">
                                          <i class="bi bi-chat-heart fs-1 text-primary"></i>
                                    </div>
                                    <h4>Share Reviews</h4>
                                    <p class="text-secondary">Read and write reviews to help others plan their
                                          adventures.</p>
                              </div>
                        </div>
                        <div class="col-md-4">
                              <div class="feature-card text-center p-4 rounded">
                                    <div class="feature-icon mb-3">
                                          <i class="bi bi-people fs-1 text-primary"></i>
                                    </div>
                                    <h4>Join Community</h4>
                                    <p class="text-secondary">Connect with fellow trekkers and share your experiences.
                                    </p>
                              </div>
                        </div>
                  </div>
            </div>
      </section>