<% layout('layouts/boilerplate') %>
      <div id="map"
            data-maptiler-key="<%= maptilerKey %>"
            data-treks='<%= JSON.stringify(trekkings) %>'
            style="width: 100%; height: 400px;">

      </div>
      <div class="container mt-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                  <h1 class="mb-0">All Trekking Spots</h1>
                  <a href="/treks/new" class="btn btn-primary">
                        <i class="bi bi-plus"></i>Add New
                  </a>
            </div>

            <% if(trekkings.length===0) { %>
                  <div class="text-center py-5">
                        <i class="bi bi-geo-alt display-1 text-secondary"></i>
                        <h3 class="mt-3">No Trekking Spots Yet</h3>
                        <p class="text-secondary">Be the first to add a trekking spot!</p>
                        <a href="/treks/new" class="btn btn-primary mt-2">Add First Trek</a>
                  </div>
                  <% } else { %>
                        <div class="row g-4">
                              <% for(let spot of trekkings) { %>
                                    <div class="col-md-6 col-lg-4">
                                          <div class="card h-100 trek-card shadow-sm">
                                                <div class="card-img-wrapper">
                                                      <!-- <% for(let img of spot.image) { %>
                                                            <img src="<%= img.url %>" alt="<%= img.filename %>">
                                                            <% } %> -->
                                                      <img src="<%= spot.image[0].url %>" alt="<%= spot.name %>">

                                                      <div class="card-img-overlay d-flex align-items-end">
                                                            <span class="badge bg-primary">
                                                                  <i class="bi bi-geo-alt me-1"></i>
                                                                  <%= spot.location %>
                                                            </span>
                                                      </div>
                                                </div>
                                                <div class="card-body">
                                                      <h5 class="card-title fw-bold">
                                                            <%= spot.name %>
                                                      </h5>
                                                      <p class="card-text text-secondary">
                                                            <% if(spot.description && spot.description.length> 100) { %>
                                                                  <%= spot.description.substring(0, 100) %>...
                                                                        <% } else { %>
                                                                              <%= spot.description %>
                                                                                    <% } %>
                                                      </p>
                                                      <% if(spot.district) { %>
                                                            <p class="mb-2">
                                                                  <small class="text-muted">
                                                                        <i class="bi bi-map me-1"></i>
                                                                        <%= spot.district %>
                                                                  </small>
                                                            </p>
                                                            <% } %>
                                                </div>
                                                <div class="card-footer bg-transparent border-0 pb-3">
                                                      <a href="/treks/<%= spot._id %>"
                                                            class="btn btn-outline-primary w-100">
                                                            View Details <i class="bi bi-arrow-right ms-1"></i>
                                                      </a>
                                                </div>
                                          </div>
                                    </div>
                                    <% } %>
                        </div>
                        <% } %>
      </div>