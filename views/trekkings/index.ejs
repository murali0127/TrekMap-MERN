<% layout('layouts/boilerplate') %>

      <div class="container mt-5">
            <h1>All Trekking Spots</h1>
            <% for(let spot of trekkings) { %>
                  <div class="card mt-2">
                        <div class="row">
                              <div class="col-md-4">
                                    <img class="img-fluid rounded" style="width:100%;height:20rem"
                                          src="<%= spot.image %>" alt="<%= spot.name %>">
                              </div>
                              <div class="col-md-8">
                                    <div class="card-body">
                                          <h4 class="card-title">
                                                <%= spot.name %>
                                          </h4>
                                          <p class="text">
                                                <%= spot.location %>
                                          </p>
                                          <p class="text-secondary">
                                                <%= spot.description %>
                                          </p>
                                          <a href="/treks/<%= spot._id %>" class="btn btn-primary">view</a>
                                    </div>
                              </div>
                        </div>
                  </div>
                  <% } %>
      </div>
      <a href="/treks/new" class="btn btn-primary mt-3 mb-3">Add New</a>