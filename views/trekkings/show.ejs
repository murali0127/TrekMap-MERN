<% layout('layouts/boilerplate') %>

      <link rel="stylesheet" href="/css/stars.css">
      <div class="container mt-4 mb-5">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-4">
                  <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                        <li class="breadcrumb-item"><a href="/treks">Trekkings</a></li>
                        <li class="breadcrumb-item active">
                              <%= data.name %>
                        </li>
                  </ol>
            </nav>

            <div class="row g-4">
                  <!-- Trek Details -->
                  <div class="col-lg-7">
                        <div class="card shadow-sm">
                              <% if(data.image && data.image.length> 0) { %>
                                    <div id="trekCarousel" class="carousel slide" data-bs-ride="carousel">
                                          <div class="carousel-inner">
                                                <% data.image.forEach((img, i)=> { %>
                                                      <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                                                            <img src="<%= img.url %>" class="d-block w-100"
                                                                  alt="<%= data.name %>"
                                                                  style="height: 400px; object-fit: cover;">
                                                      </div>
                                                      <% }) %>
                                          </div>
                                          <% if(data.image.length> 1) { %>
                                                <button class="carousel-control-prev" type="button"
                                                      data-bs-target="#trekCarousel" data-bs-slide="prev">
                                                      <span class="carousel-control-prev-icon"></span>
                                                </button>
                                                <button class="carousel-control-next" type="button"
                                                      data-bs-target="#trekCarousel" data-bs-slide="next">
                                                      <span class="carousel-control-next-icon"></span>
                                                </button>
                                                <% } %>
                                    </div>
                                    <% } else { %>
                                          <div class="card-img-wrapper-large">
                                                <img src="https://res.cloudinary.com/demo/image/upload/v1312461204/sample.jpg"
                                                      alt="No image available">
                                          </div>
                                          <% } %>
                                                <div class="card-body">
                                                      <h1 class="card-title display-5 fw-bold">
                                                            <%= data.name %>
                                                      </h1>
                                                      <p class="card-text lead text-secondary">
                                                            <%= data.description %>
                                                      </p>
                                                      <% if(data.author){ %>
                                                            <p class="card-text lead text-secondary">
                                                                  Created by -
                                                                  <a href="/user/profile/<%= data.author._id%>">
                                                                        <img src="<%= data.author.avatar %>"
                                                                              alt="<%= data.author.displayName %>"
                                                                              class="rounded-circle" width="30" />
                                                                        <% if(data.author.displayName){ %>
                                                                              <%= data.author.displayName %>

                                                                                    <% } else{ %>

                                                                                          <%= data.author.username %>
                                                                                                <% } %>
                                                                  </a>
                                                            </p>
                                                            <% } %>

                                                                  <div class="row g-3 mt-3">
                                                                        <div class="col-sm-6">
                                                                              <div class="info-box p-3 rounded bg-dark">
                                                                                    <i
                                                                                          class="bi bi-geo-alt text-primary fs-4"></i>
                                                                                    <h6 class="mt-2 mb-1">Location</h6>
                                                                                    <p class="mb-0 text-secondary">
                                                                                          <%= data.location %>
                                                                                    </p>
                                                                              </div>
                                                                        </div>
                                                                        <div class="col-sm-6">
                                                                              <div class="info-box p-3 rounded bg-dark">
                                                                                    <i
                                                                                          class="bi bi-map text-primary fs-4"></i>
                                                                                    <h6 class="mt-2 mb-1">District</h6>
                                                                                    <p class="mb-0 text-secondary">
                                                                                          <%= data.district %>
                                                                                    </p>
                                                                              </div>
                                                                        </div>
                                                                  </div>
                                                                  <% if(currentUser && data.author &&
                                                                        data.author.equals(currentUser._id)){ %>

                                                                        <div class="d-flex gap-2 mt-4">
                                                                              <a href="/treks/<%= data._id %>/edit"
                                                                                    class="btn btn-warning">
                                                                                    <i
                                                                                          class="bi bi-pencil me-2"></i>Edit
                                                                              </a>
                                                                              <form action="/treks/<%= data._id %>?_method=DELETE"
                                                                                    method="post" class="d-inline">
                                                                                    <button type="submit"
                                                                                          class="btn btn-outline-danger"
                                                                                          onclick="return confirm('Are you sure you want to delete this trek?')">
                                                                                          <i
                                                                                                class="bi bi-trash me-2"></i>Delete
                                                                                    </button>
                                                                              </form>
                                                                        </div>
                                                                        <% } %>

                                                                              <a href="/treks" id="back-btn"
                                                                                    class="btn btn-outline-secondary ms-auto mt-4">
                                                                                    <i
                                                                                          class="bi bi-arrow-left me-2"></i>Back
                                                                                    to All
                                                                              </a>
                                                </div>
                        </div>

                        <!-- Map -->
                        <% if(data.coordinates && data.coordinates.coordinates &&
                              data.coordinates.coordinates.length===2) { %>
                              <div class="card shadow-sm mt-4">
                                    <div class="card-header bg-primary">
                                          <h4 class="mb-0 text-white">
                                                <i class="bi bi-pin-angle-fill me-2"></i>
                                                <%=data.name %> Location
                                          </h4>
                                    </div>
                                    <div id="trek-map" data-lng="<%= data.coordinates.coordinates[0] %>"
                                          data-lat="<%= data.coordinates.coordinates[1] %>" data-name="<%= data.name %>"
                                          data-maptiler-key="<%= process.env.MAPTILER_KEY %>"
                                          style="width:100%; height:400px; border-radius: 0 0 0.375rem 0.375rem;">
                                    </div>
                              </div>
                              <% } %>
                  </div>

                  <!-- Reviews Section -->
                  <div class="col-lg-5">
                        <div class="card shadow-sm">
                              <div class="card-header bg-primary">
                                    <h4 class="mb-0 text-white">
                                          <i class="bi bi-chat-heart me-2"></i>Reviews
                                    </h4>
                              </div>

                              <div class="card-body">
                                    <% if(currentUser) { %>
                                          <!-- Review Form -->
                                          <h6 class="mb-3">Leave a Review</h6>
                                          <form action="/treks/<%= data._id %>/review" method="post" novalidate
                                                class="validated-form">

                                                <div class="mb-3">
                                                      <label class="form-label">Rating</label>
                                                      <div class="rating-input">
                                                            <fieldset class="starability-fade">
                                                                  <input type="radio" id="no-rate" class="input-no-rate"
                                                                        name="review[rating]" value="0" checked
                                                                        aria-label="No rating." />
                                                                  <input type="radio" id="rate1" name="review[rating]"
                                                                        value="1" />
                                                                  <label for="rate1">1 star.</label>

                                                                  <input type="radio" id="rate2" name="review[rating]"
                                                                        value="2" />
                                                                  <label for="rate2">2 stars.</label>

                                                                  <input type="radio" id="rate3" name="review[rating]"
                                                                        value="3" />
                                                                  <label for="rate3">3 stars.</label>

                                                                  <input type="radio" id="rate4" name="review[rating]"
                                                                        value="4" />
                                                                  <label for="rate4">4 stars.</label>

                                                                  <input type="radio" id="rate5" name="review[rating]"
                                                                        value="5" />
                                                                  <label for="rate5">5 stars.</label>

                                                                  <span class="starability-focus-ring"></span>
                                                            </fieldset>
                                                      </div>

                                                </div>
                                                <div class="mb-3">
                                                      <label for="body" class="form-label">Your Review</label>
                                                      <textarea name="review[body]" id="body" class="form-control"
                                                            rows="3" placeholder="Share your experience..."
                                                            required></textarea>
                                                      <div class="invalid-feedback">Please write your review before
                                                            submitting.</div>
                                                </div>
                                                <button type="submit" class="btn btn-primary w-100">
                                                      <i class="bi bi-send me-2"></i>Submit Review
                                                </button>
                                          </form>

                                          <% } %>
                                                <hr class="my-4">

                                                <!-- Reviews List -->
                                                <h6 class="mb-3">
                                                      <% if(data.reviews && data.reviews.length> 0) { %>
                                                            <span class="badge bg-secondary">
                                                                  <%= data.reviews.length %> Reviews
                                                            </span>
                                                            <% } %>
                                                </h6>

                                                <% if(data.reviews && data.reviews.length> 0) { %>
                                                      <div class="reviews-list">
                                                            <% for(let review of data.reviews) { %>
                                                                  <div class="review-card p-3 mb-3 rounded bg-dark">
                                                                        <div
                                                                              class="d-flex justify-content-between align-items-start">
                                                                              <div class="star-rating">
                                                                                    <% for(let i=1; i <=5; i++) { %>
                                                                                          <% if(i <=review.rating) { %>
                                                                                                <i
                                                                                                      class="bi bi-star-fill text-warning"></i>
                                                                                                <% } else { %>
                                                                                                      <i
                                                                                                            class="bi bi-star text-secondary"></i>
                                                                                                      <% } %>
                                                                                                            <% } %>
                                                                              </div>
                                                                              <% if(currentUser &&
                                                                                    review.author._id.toString()===currentUser._id.toString()
                                                                                    ){ %>
                                                                                    <form action="/treks/<%= data._id %>/review/<%= review._id %>?_method=DELETE"
                                                                                          method="POST">
                                                                                          <button
                                                                                                class="btn btn-sm btn-outline-danger">
                                                                                                <i
                                                                                                      class="bi bi-trash"></i>
                                                                                          </button>
                                                                                    </form>
                                                                                    <% } %>
                                                                        </div>
                                                                        <p class="mb-0 mt-2">
                                                                              <%= review.body %>
                                                                        </p>
                                                                        <% if(review.author){ %>
                                                                              <p class="mb-0 mt-2 text-secondary">By -
                                                                                    <%= review.author.username ?
                                                                                          review.author.username :
                                                                                          review.author.displayName%>
                                                                              </p>
                                                                              <% } %>
                                                                  </div>
                                                                  <% } %>
                                                      </div>
                                                      <% } else { %>
                                                            <div class="text-center py-4 text-secondary">
                                                                  <i class="bi bi-chat-square display-4"></i>
                                                                  <p class="mt-2">No reviews yet. Be the first to
                                                                        review!</p>
                                                            </div>
                                                            <% } %>
                              </div>
                        </div>
                  </div>
                  <!-- Food Section -->
                  <% if(foodData && foodData.length> 0) { %>
                        <div class="col-12 mt-5">
                              <div class="card shadow-sm">
                                    <div class="card-header bg-primary">
                                          <h4 class="mb-0 text-white">
                                                <i class="bi bi-cup-straw me-2"></i>Recommended Foods in <%=
                                                      data.district %>
                                          </h4>
                                    </div>
                                    <div class="card-body">
                                          <div class="row g-4">
                                                <% for(let food of foodData){ %>
                                                      <div class="col-md-6 col-lg-4">
                                                            <div class="card h-100 food-card shadow-sm hover-lift">
                                                                  <div class="card-img-wrapper position-relative">
                                                                        <% if(food.image) { %>
                                                                              <img src="<%= food.image %>"
                                                                                    alt="<%= food.name %>"
                                                                                    class="food-card-img">
                                                                              <% } else { %>
                                                                                    <img src="https://placehold.net/400x600.png"
                                                                                          alt="No image"
                                                                                          class="food-card-img">
                                                                                    <% } %>
                                                                                          <div class="food-overlay">
                                                                                                <span
                                                                                                      class="badge <%= food.veg ? 'bg-success' : 'bg-danger' %>">
                                                                                                      <i
                                                                                                            class="bi bi-<%= food.veg ? 'check-circle' : 'x-circle' %> me-1"></i>
                                                                                                      <%= food.veg
                                                                                                            ? 'Veg'
                                                                                                            : 'Non-Veg'
                                                                                                            %>
                                                                                                </span>
                                                                                          </div>
                                                                  </div>
                                                                  <div class="card-body d-flex flex-column">
                                                                        <h6 class="card-title fw-bold">
                                                                              <%= food.name %>
                                                                        </h6>
                                                                        <p
                                                                              class="card-text text-secondary small flex-grow-1">
                                                                              <%= (food.description &&
                                                                                    food.description.length> 150)
                                                                                    ? food.description.substring(0, 80)
                                                                                    + '...'
                                                                                    : food.description %>
                                                                        </p>
                                                                        <div
                                                                              class="d-flex justify-content-between align-items-center mt-3">
                                                                              <span class="badge bg-primary">
                                                                                    <i class="bi bi-geo-alt me-1"></i>
                                                                                    <%= food.district %>
                                                                              </span>
                                                                              <% if(food.pricerange) { %>
                                                                                    <span
                                                                                          class="text-success fw-semibold">
                                                                                          <i
                                                                                                class="bi bi-currency-rupee"></i>
                                                                                          <%= food.pricerange %>
                                                                                    </span>
                                                                                    <% } %>
                                                                        </div>
                                                                        <% if(food.tags && food.tags.length> 0) { %>
                                                                              <div class="mt-2 d-flex flex-wrap gap-1">
                                                                                    <% food.tags.slice(0,
                                                                                          4).forEach(tag=> { %>
                                                                                          <span
                                                                                                class="badge bg-light text-dark border">
                                                                                                #<%= tag %>
                                                                                          </span>
                                                                                          <% }) %>
                                                                              </div>
                                                                              <% } %>
                                                                  </div>
                                                            </div>
                                                      </div>
                                                      <% } %>
                                          </div>
                                    </div>
                              </div>
                        </div>
                        <% } %>
                              <!-- Hotel Section -->

                              <% if(hotels && hotels.length> 0) { %>
                                    <div class="col-12 mt-5">
                                          <div class="card shadow-sm">
                                                <div class="card-header bg-primary">
                                                      <h4 class="mb-0 text-white">
                                                            <i class="bi bi-suitcase2-fill me-2"></i>Recommended
                                                            Hotels in <%= data.district %>
                                                      </h4>
                                                </div>
                                                <div class="card-body">
                                                      <div class="row g-4">
                                                            <% for(let hotel of hotels){ %>
                                                                  <div class="col-md-6 col-lg-4">
                                                                        <div
                                                                              class="card h-100 food-card shadow-sm hover-lift">
                                                                              <div
                                                                                    class="card-img-wrapper position-relative">
                                                                                    <% if(hotel.image) { %>
                                                                                          <img src="<%= hotel.image %>"
                                                                                                alt="<%= hotel.name %>"
                                                                                                class="food-card-img">
                                                                                          <% } else { %>
                                                                                                <img src="https://placehold.net/400x600.png"
                                                                                                      alt="No image"
                                                                                                      class="food-card-img">
                                                                                                <% } %>
                                                                                                      <div
                                                                                                            class="food-overlay">
                                                                                                            <span
                                                                                                                  class="badge bg-success">
                                                                                                                  <% if(hotel.rating)
                                                                                                                        {
                                                                                                                        %>
                                                                                                                        <%= hotel.rating
                                                                                                                              %>
                                                                                                                              <i
                                                                                                                                    class="bi bi-star-fill"></i>
                                                                                                                              <% }
                                                                                                                                    %>
                                                                                                            </span>
                                                                                                            <% if(hotel.distanceFromTrek)
                                                                                                                  { %>
                                                                                                                  <span
                                                                                                                        class="badge bg-danger text-white mt-1">
                                                                                                                        <i
                                                                                                                              class="bi bi-signpost-2"></i>
                                                                                                                        <%= hotel.distanceFromTrek
                                                                                                                              %>
                                                                                                                              km
                                                                                                                              away
                                                                                                                  </span>
                                                                                                                  <% }
                                                                                                                        %>
                                                                                                      </div>
                                                                              </div>
                                                                              <div class="card-body d-flex flex-column">
                                                                                    <h6 class="card-title fw-bold">
                                                                                          <%= hotel.name %>
                                                                                    </h6>
                                                                                    <p class="mb-1 text-muted small">
                                                                                          <i class="bi bi-geo-alt"></i>
                                                                                          <%= hotel.location.address %>,
                                                                                                <%= hotel.district %>,
                                                                                                      <%= hotel.state %>
                                                                                    </p>
                                                                                    <p
                                                                                          class="card-text text-secondary small flex-grow-1">
                                                                                          <%= (hotel.description &&
                                                                                                hotel.description.length>
                                                                                                150)
                                                                                                ?
                                                                                                hotel.description.substring(0,
                                                                                                80) + '...'
                                                                                                : hotel.description %>
                                                                                    </p>

                                                                                    <!-- Contact Info -->
                                                                                    <% if(hotel.contact) { %>
                                                                                          <div class="mt-2 small">
                                                                                                <% if(hotel.contact.phone)
                                                                                                      { %>
                                                                                                      <p
                                                                                                            class="mb-1 text-muted">
                                                                                                            <i
                                                                                                                  class="bi bi-telephone"></i>
                                                                                                            <%= hotel.contact.phone
                                                                                                                  %>
                                                                                                      </p>
                                                                                                      <% } %>
                                                                                                            <% if(hotel.contact.alternatePhone)
                                                                                                                  { %>
                                                                                                                  <p
                                                                                                                        class="mb-1 text-muted">
                                                                                                                        <i
                                                                                                                              class="bi bi-telephone-outbound"></i>
                                                                                                                        <%= hotel.contact.alternatePhone
                                                                                                                              %>
                                                                                                                  </p>
                                                                                                                  <% }
                                                                                                                        %>
                                                                                                                        <% if(hotel.contact.website)
                                                                                                                              {
                                                                                                                              %>
                                                                                                                              <p
                                                                                                                                    class="mb-1 text-muted">
                                                                                                                                    <i
                                                                                                                                          class="bi bi-globe"></i>
                                                                                                                                    <a href="<%= hotel.contact.website %>"
                                                                                                                                          target="_blank"
                                                                                                                                          class="text-decoration-none">
                                                                                                                                          Visit
                                                                                                                                          Website
                                                                                                                                    </a>
                                                                                                                              </p>
                                                                                                                              <% }
                                                                                                                                    %>
                                                                                          </div>
                                                                                          <% } %>

                                                                                                <div
                                                                                                      class="d-flex justify-content-between align-items-center mt-3">
                                                                                                      <span
                                                                                                            class="badge bg-primary">
                                                                                                            <i
                                                                                                                  class="bi bi-geo-alt me-1"></i>
                                                                                                            <%= hotel.district
                                                                                                                  %>
                                                                                                      </span>
                                                                                                      <% if(hotel.pricerange)
                                                                                                            { %>
                                                                                                            <span
                                                                                                                  class="text-success fw-semibold">
                                                                                                                  <i
                                                                                                                        class="bi bi-currency-rupee"></i>
                                                                                                                  <%= hotel.pricerange
                                                                                                                        %>
                                                                                                                        /
                                                                                                                        night
                                                                                                            </span>
                                                                                                            <% } %>
                                                                                                </div>

                                                                                                <% if(hotel.aminities &&
                                                                                                      hotel.aminities.length>
                                                                                                      0) { %>
                                                                                                      <div class="mt-2">
                                                                                                            <small
                                                                                                                  class="text-muted"><strong>Amenities:</strong></small>
                                                                                                            <div
                                                                                                                  class="mt-1 d-flex flex-wrap gap-1">
                                                                                                                  <% hotel.aminities.slice(0,
                                                                                                                        5).forEach(amenity=>
                                                                                                                        {
                                                                                                                        %>
                                                                                                                        <span
                                                                                                                              class="badge bg-light text-dark border">
                                                                                                                              <%= amenity
                                                                                                                                    %>
                                                                                                                        </span>
                                                                                                                        <% })
                                                                                                                              %>
                                                                                                                              <%
                                                                                                                                    if(hotel.aminities.length>
                                                                                                                                    5)
                                                                                                                                    {
                                                                                                                                    %>
                                                                                                                                    <span
                                                                                                                                          class="badge bg-secondary">
                                                                                                                                          +
                                                                                                                                          <%= hotel.aminities.length
                                                                                                                                                -
                                                                                                                                                5
                                                                                                                                                %>
                                                                                                                                                more
                                                                                                                                    </span>
                                                                                                                                    <% }
                                                                                                                                          %>
                                                                                                            </div>
                                                                                                      </div>
                                                                                                      <% } %>

                                                                                                            <% if(hotel.bookingAvailable)
                                                                                                                  { %>
                                                                                                                  <div
                                                                                                                        class="mt-2">
                                                                                                                        <span
                                                                                                                              class="badge bg-success">
                                                                                                                              <i
                                                                                                                                    class="bi bi-check-circle"></i>
                                                                                                                              Booking
                                                                                                                              Available
                                                                                                                        </span>
                                                                                                                  </div>
                                                                                                                  <% }
                                                                                                                        %>
                                                                              </div>
                                                                        </div>
                                                                  </div>
                                                                  <% } %>
                                                      </div>
                                                </div>
                                          </div>
                                    </div>
                                    <% } %>
            </div>
      </div>

      <style>
            .food-card {
                  transition: transform 0.3s ease, box-shadow 0.3s ease;
                  border: none;
                  overflow: hidden;
            }

            .food-card:hover {
                  transform: translateY(-5px);
                  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15) !important;
            }

            .food-card-img {
                  width: 100%;
                  height: 200px;
                  object-fit: cover;
                  transition: transform 0.3s ease;
            }

            .food-card:hover .food-card-img {
                  transform: scale(1.05);
            }

            .card-img-wrapper {
                  overflow: hidden;
                  position: relative;
            }

            .food-overlay {
                  position: absolute;
                  top: 10px;
                  left: 10px;
            }

            .hover-lift {
                  position: relative;
            }
      </style>