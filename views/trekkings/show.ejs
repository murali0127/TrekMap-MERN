<% layout('layouts/boilerplate') %>
      <div class="row">
            <div class="col-6 offset-3">
                  <!--style="width: 25rem;"-->
                  <div class="card md-3 mt-5">

                        <img src="<%= data.image %>" style="width:100%;height:25rem" class="card-img-top"
                              alt="<%= data.name %>">
                        <div class="card-body">
                              <h1 class="card-title ">Details About <%= data.name%>. </h1>
                              <p class="card-text text-muted">
                                    <%= data.description %>
                              </p>
                              <ul class="list-group list-group-flush">
                                    <li class="list-group-item">Location : <%= data.location %>
                                    </li>
                                    <li class="list-group-item">District : <%= data.district %>
                                    </li>
                              </ul>
                              <div class="card-body">
                                    <a href="/treks/<%= data._id %>/edit" class="btn btn-primary card-link">Edit</a>
                                    <form action="/treks/<%= data._id %>?_method=DELETE" method="post" class="mt-2">
                                          <button type="submit" class="btn btn-danger card-link">Delete</button>
                                    </form>
                              </div>

                        </div>
                        <div class="card-footer text-muted">
                              2 days ago
                        </div>

                  </div>
                  <div class="container mt-2">
                        <h3>Leave a Review</h3>
                        <form action="/treks/<%= data._id %>/review" method="post">
                              <label class="form-label" for="rating">Ratings : </label>
                              <input type="range" class="form-range" min="0" max="5" step="1" name="review[rating]"
                                    id="rating" />
                              <label for="body" class="from-label">Reviews : </label>
                              <textarea name="review[body]" id="body" class="form-control"></textarea>
                              <button class="mt-2 btn btn-primary">submit</button>
                        </form>
                  </div>
            </div>
      </div>