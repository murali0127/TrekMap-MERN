<%- layout('layouts/boilerplate') %>

      <style>
            :root {
                  --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                  --primary-color: #667eea;
                  --primary-hover: #5a6fd6;
                  --secondary-color: #764ba2;
            }

            [data-bs-theme="light"] {
                  --bg-card: #ffffff;
                  --bg-section: #f8f9fa;
                  --text-primary: #212529;
                  --text-secondary: #6c757d;
                  --border-color: #dee2e6;
                  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.08);
                  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.1);
                  --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.12);
                  --hover-elevate: translateY(-4px);
            }

            [data-bs-theme="dark"] {
                  --bg-card: #2b2b2b;
                  --bg-section: #1f1f1f;
                  --text-primary: #f8f9fa;
                  --text-secondary: #adb5bd;
                  --border-color: #444444;
                  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.3);
                  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.4);
                  --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.5);
                  --hover-elevate: translateY(-4px);
            }

            /* Profile Header Styles */
            .profile-header {
                  background: var(--primary-gradient);
                  border-radius: 15px;
                  padding: 2rem;
                  color: white;
                  position: relative;
                  overflow: hidden;
                  box-shadow: var(--shadow-md);
            }

            .profile-header::before {
                  content: '';
                  position: absolute;
                  top: -50%;
                  right: -50%;
                  width: 200%;
                  height: 200%;
                  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
                  animation: pulse 4s ease-in-out infinite;
            }

            @keyframes pulse {

                  0%,
                  100% {
                        transform: scale(1);
                        opacity: 0.5;
                  }

                  50% {
                        transform: scale(1.1);
                        opacity: 0.8;
                  }
            }

            .profile-avatar {
                  width: 120px;
                  height: 120px;
                  object-fit: cover;
                  border: 4px solid rgba(255, 255, 255, 0.3);
                  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
                  transition: transform 0.3s ease;
            }

            .profile-avatar:hover {
                  transform: scale(1.05);
            }

            .profile-info {
                  position: relative;
                  z-index: 1;
            }

            .profile-name {
                  font-size: 2rem;
                  font-weight: 700;
                  margin-bottom: 0.5rem;
            }

            .profile-username {
                  opacity: 0.9;
                  font-size: 1.1rem;
            }

            .profile-badge {
                  background: rgba(255, 255, 255, 0.2);
                  backdrop-filter: blur(10px);
                  border: 1px solid rgba(255, 255, 255, 0.3);
                  color: white;
            }

            /* Stats Section */
            .stats-container {
                  display: grid;
                  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
                  gap: 1rem;
                  margin-top: -30px;
                  position: relative;
                  z-index: 2;
            }

            .stat-card {
                  background: var(--bg-card);
                  border-radius: 12px;
                  padding: 1.5rem;
                  text-align: center;
                  box-shadow: var(--shadow-md);
                  transition: transform 0.3s ease, box-shadow 0.3s ease;
                  border: 1px solid var(--border-color);
            }

            .stat-card:hover {
                  transform: var(--hover-elevate);
                  box-shadow: var(--shadow-lg);
            }

            .stat-value {
                  font-size: 2rem;
                  font-weight: 700;
                  color: var(--primary-color);
            }

            .stat-label {
                  color: var(--text-secondary);
                  font-size: 0.9rem;
                  margin-top: 0.25rem;
            }

            /* About Section */
            .about-section {
                  background: var(--bg-card);
                  border-radius: 12px;
                  padding: 1.5rem;
                  margin-top: 1.5rem;
                  box-shadow: var(--shadow-md);
                  border: 1px solid var(--border-color);
            }

            .section-title {
                  font-size: 1.25rem;
                  font-weight: 600;
                  color: var(--text-primary);
                  margin-bottom: 1rem;
                  display: flex;
                  align-items: center;
                  gap: 0.5rem;
            }

            .section-title i {
                  color: var(--primary-color);
            }

            /* Social Links */
            .social-links {
                  display: flex;
                  gap: 0.75rem;
                  flex-wrap: wrap;
            }

            .social-link {
                  display: inline-flex;
                  align-items: center;
                  gap: 0.5rem;
                  padding: 0.5rem 1rem;
                  border-radius: 8px;
                  text-decoration: none;
                  color: white;
                  font-size: 0.9rem;
                  transition: transform 0.2s ease, opacity 0.2s ease;
            }

            .social-link:hover {
                  transform: translateY(-2px);
                  opacity: 0.9;
                  color: white;
            }

            .social-twitter {
                  background: #1DA1F2;
            }

            .social-instagram {
                  background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
            }

            .social-facebook {
                  background: #4267B2;
            }

            .social-linkedin {
                  background: #0A66C2;
            }

            .social-website {
                  background: #34A853;
            }

            /* Trek Grid */
            .treks-section {
                  background: var(--bg-card);
                  border-radius: 12px;
                  padding: 1.5rem;
                  margin-top: 1.5rem;
                  box-shadow: var(--shadow-md);
                  border: 1px solid var(--border-color);
            }

            .trek-card {
                  border-radius: 10px;
                  overflow: hidden;
                  transition: transform 0.3s ease, box-shadow 0.3s ease;
                  box-shadow: var(--shadow-sm);
                  border: 1px solid var(--border-color);
                  background: var(--bg-card);
            }

            .trek-card:hover {
                  transform: var(--hover-elevate);
                  box-shadow: var(--shadow-lg);
            }

            .trek-image {
                  height: 200px;
                  object-fit: cover;
                  width: 100%;
            }

            .trek-title {
                  font-size: 1rem;
                  font-weight: 600;
                  color: var(--text-primary);
                  margin: 0.75rem 0;
            }

            .trek-title a {
                  color: var(--text-primary);
            }

            .trek-title a:hover {
                  color: var(--primary-color);
            }

            .trek-location {
                  font-size: 0.85rem;
                  color: var(--text-secondary);
            }

            .treks-detail {
                  text-align: center;
                  padding: 3rem 1rem;
                  color: var(--text-secondary);
            }

            .treks-detail i {
                  font-size: 4rem;
                  margin-bottom: 1rem;
                  opacity: 0.5;
            }

            .treks-detail h4 {
                  color: var(--text-primary);
            }

            .treks-detail p {
                  color: var(--text-secondary);
            }

            /* Edit Button */
            .edit-btn {
                  background: rgba(255, 255, 255, 0.2);
                  backdrop-filter: blur(10px);
                  border: 1px solid rgba(255, 255, 255, 0.3);
                  color: white;
                  padding: 0.5rem 1.5rem;
                  border-radius: 8px;
                  text-decoration: none;
                  transition: all 0.3s ease;
            }

            .edit-btn:hover {
                  background: rgba(255, 255, 255, 0.3);
                  color: white;
            }

            /* Member Since */
            .member-since {
                  font-size: 0.9rem;
                  opacity: 0.8;
                  margin-top: 0.5rem;
                  color: white;
            }

            /* Buttons */
            .btn-outlined {
                  background: var(--primary-gradient);
                  border: none;
                  color: white;
                  padding: 0.5rem 1.5rem;
                  border-radius: 8px;
                  text-decoration: none;
                  transition: transform 0.2s ease, box-shadow 0.2s ease;
            }

            .btn-outlined:hover {
                  transform: translateY(-2px);
                  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
                  color: white;
            }
      </style>

      <div class="container py-5">
            <!-- Profile Header -->
            <div class="profile-header mb-4">
                  <div class="d-flex align-items-center gap-4 profile-info">
                        <% if(user.avatar) { %>
                              <img src="<%= user.avatar %>" referrerpolicy="noreferrer" class="profile-avatar"
                                    alt="<%= user.username %>" />
                              <% } else { %>
                                    <div class="profile-avatar d-flex align-items-center justify-content-center bg-white text-primary"
                                          style="font-size: 3rem; font-weight: bold;">
                                          <%= (user.displayName || user.username || 'U' ).charAt(0).toUpperCase() %>
                                    </div>
                                    <% } %>

                                          <div class="flex-grow-1">
                                                <h1 class="profile-name">
                                                      <%= user.displayName || user.username || 'Anonymous User' %>
                                                </h1>
                                                <p class="profile-username">
                                                      @<%= user.username || 'user' %>
                                                </p>
                                                <div class="d-flex align-items-center gap-3 mt-2">
                                                      <span class="badge profile-badge">
                                                            <i class="fas fa-shield-alt me-1"></i>
                                                            <%= user.role==='admin' ? 'Administrator' : 'Member' %>
                                                      </span>
                                                      <span class="member-since">
                                                            <i class="far fa-calendar-alt me-1"></i>
                                                            Joined <%= new Date(user.createdAt ||
                                                                  Date.now()).toLocaleDateString('en-US', {
                                                                  month: 'long' , year: 'numeric' }) %>
                                                      </span>
                                                </div>
                                          </div>

                                          <a href="/user/profile/<%= user._id %>/edit" class="edit-btn">
                                                <i class="fas fa-edit me-1"></i> Edit Profile
                                          </a>
                  </div>
            </div>

            <!-- Stats Section -->
            <div class="stats-container">
                  <div class="stat-card">
                        <div class="stat-value">
                              <%= typeof treksCount !=='undefined' ? treksCount : (user.treks ? user.treks.length : 0)
                                    %>
                        </div>
                        <div class="stat-label">
                              <i class="fas fa-hiking me-1"></i> Treks Created
                        </div>
                  </div>
                  <div class="stat-card">
                        <div class="stat-value">
                              <%= user.stats.reviewsWritten ? user.stats.reviewsWritten : 0 %>
                        </div>
                        <div class="stat-label">
                              <i class="fas fa-comment-alt me-1"></i> Reviews
                        </div>
                  </div>

            </div>



            <!-- About & Info Section -->
            <div class="about-section">
                  <h3 class="section-title">
                        <i class="fas fa-user"></i> About <%= user.displayName || user.username %>
                  </h3>
                  <% if (user.bio) { %>
                        <p class="text-muted mb-3">
                              <%= user.bio %>
                        </p>
                        <% } else { %>
                              <p class="text-muted mb-3 fst-italic">No bio added yet.</p>
                              <% } %>

                                    <% if (user.location || user.website || user.socialLinks) { %>
                                          <div class="row mt-4">
                                                <% if (user.location) { %>
                                                      <div class="col-md-6 mb-2">
                                                            <strong><i
                                                                        class="fas fa-map-marker-alt me-2 text-primary"></i>Location:</strong>
                                                            <span class="text-muted ms-2">
                                                                  <%= user.location %>
                                                            </span>
                                                      </div>
                                                      <% } %>
                                                            <% if (user.website) { %>
                                                                  <div class="col-md-6 mb-2">
                                                                        <strong><i
                                                                                    class="fas fa-globe me-2 text-primary"></i>Website:</strong>
                                                                        <a href="<%= user.website %>" target="_blank"
                                                                              rel="noopener" class="ms-2">
                                                                              <%= user.website.replace(/^https?:\/\//, ''
                                                                                    ) %>
                                                                        </a>
                                                                  </div>
                                                                  <% } %>
                                          </div>
                                          <% } %>

                                                <!-- Social Links -->
                                                <% if (user.socialLinks && (user.socialLinks.twitter ||
                                                      user.socialLinks.instagram || user.socialLinks.facebook ||
                                                      user.socialLinks.linkedin)) { %>
                                                      <div class="mt-3">
                                                            <strong><i class="bi bi-link-45deg"></i>Social
                                                                  Links:</strong>
                                                            <div class="social-links mt-2">
                                                                  <% if (user.socialLinks.twitter) { %>
                                                                        <a href="<%= user.socialLinks.twitter %>"
                                                                              target="_blank" rel="noopener"
                                                                              class="social-link social-twitter">
                                                                              <i class="bi bi-twitter-x"></i>
                                                                              Twitter
                                                                        </a>
                                                                        <% } %>
                                                                              <% if (user.socialLinks.instagram) { %>
                                                                                    <a href="<%= user.socialLinks.instagram %>"
                                                                                          target="_blank" rel="noopener"
                                                                                          class="social-link social-instagram">
                                                                                          <i
                                                                                                class="bi bi-instagram"></i>
                                                                                          Instagram
                                                                                    </a>
                                                                                    <% } %>

                                                            </div>
                                                      </div>
                                                      <% } %>
            </div>

            <!-- Treks Section -->
            <div class="treks-section">
                  <h3 class="section-title">
                        <i class="fas fa-hiking"></i> Treks Created
                  </h3>

                  <% if (user.treks && user.treks.length> 0) { %>
                        <div class="row g-4 mt-3">
                              <% user.treks.forEach(trek=> { %>
                                    <div class="col-md-4 col-sm-6">
                                          <div class="card trek-card h-100">
                                                <% if (trek.image && trek.image.length> 0) { %>
                                                      <img src="<%= trek.image[0].url %>"
                                                            class="trek-image card-img-top" alt="<%= trek.name %>" />
                                                      <% } else { %>
                                                            <div
                                                                  class="trek-image d-flex align-items-center justify-content-center bg-light">
                                                                  <i class="fas fa-mountain text-muted"
                                                                        style="font-size: 3rem;"></i>
                                                            </div>
                                                            <% } %>
                                                                  <div class="card-body">
                                                                        <h5 class="trek-title">
                                                                              <a href="/treks/<%= trek._id %>"
                                                                                    class="text-decoration-none text-dark">
                                                                                    <%= trek.name %>
                                                                              </a>
                                                                        </h5>
                                                                        <p class="trek-location">
                                                                              <i class="fas fa-map-marker-alt me-1"></i>
                                                                              <%= trek.location %>
                                                                                    <%= trek.district ? ', ' +
                                                                                          trek.district : '' %>
                                                                        </p>
                                                                  </div>
                                          </div>
                                    </div>
                                    <% }) %>
                        </div>
                        <% } else { %>
                              <div class="treks-detail">

                                    <i class="fas fa-hiking"></i>
                                    <h4>No treks created yet</h4>
                                    <p>Start your adventure by creating your first trek!</p>

                                    <a href="/treks/new">
                                          <i class="fas fa-plus me-1"></i> Create Trek
                                    </a>

                              </div>
                              <% } %>
            </div>
      </div>